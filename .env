TZ=Asia/Taipei
TZ_NAME=Asia/Taipei
APP_ENV=production
DEBUG=false

DATA_MODE=real
USE_SAMPLE_DATA=false
ALLOW_LIVE_FETCH_ON_READ=false

APP_DATA_DIR=/data
DATA_DIR=/data
PRICE_HISTORY_DIR=/data/history
KLINE_DIR=/data/history
FUNDAMENTALS_DIR=/data/fundamentals
FINANCIAL_DIR=/data/fundamentals
NEWS_DIR=/data/news
RANKING_DIR=/data/ranking
UNIVERSE_DIR=/data/universe
CACHE_DIR=/data/cache
V13_BATCH_IMPORT_DIR=/data/batch_import
V13_IMPORTED_DIR=/data/imported
V13_FINANCIAL_IMPORT_DIR=/data/financial_batch
V13_FINANCIAL_STORE_DIR=/data/financials
V13_AUTO_SCAN_IMPORT_DIR=true
V13_AUTO_SCAN_FINANCIAL_DIR=true

AUTO_UPDATE_ON_STARTUP=true
AUTO_UPDATE_RUN_IN_BACKGROUND=true
AUTO_UPDATE_INITIAL_LIMIT=20
AUTO_UPDATE_DAILY=true
AUTO_UPDATE_HOUR=19
AUTO_UPDATE_MINUTE=30
AUTO_UPDATE_FETCH_FINANCIALS=true
AUTO_UPDATE_FETCH_NEWS=true
AUTO_UPDATE_PRICE_LIMIT=60
AUTO_UPDATE_FINANCIAL_LIMIT=20
AUTO_UPDATE_NEWS_LIMIT=20
AUTO_UPDATE_TOP_LIQUIDITY_COUNT=300
AUTO_UPDATE_BUILD_RANKING=true

YFINANCE_ENABLED=true
YFINANCE_START=2010-01-01
YFINANCE_PERIOD=3mo
YFINANCE_FORCE_FULL_REFRESH=false
YFINANCE_MAX_RETRIES=3
YFINANCE_RETRY_SLEEP=8
YFINANCE_REQUEST_PAUSE=1.5
YFINANCE_BATCH_SIZE=8
YFINANCE_BATCH_PAUSE=20
YFINANCE_INCREMENTAL_OVERLAP_DAYS=10
YFINANCE_MAX_SYMBOLS_PER_RUN=60

MOPS_ENABLED=true
NEWS_ENABLED=true
RANKING_MIN_HISTORY_DAYS=120
RANKING_USE_CACHED_SNAPSHOT=true
RANKING_SNAPSHOT_MAX_AGE_MINUTES=180

V13_ENABLE_IMPORT_TOOL=true
V13_ENABLE_COST_BACKTEST=true
V13_ENABLE_TREASURE_SCREEN=true
V13_TRADING_FEE_RATE=0.001425
V13_TAX_RATE=0.003
V13_SLIPPAGE_BPS=8

TREASURE_MAX_PE=14
TREASURE_MAX_PB=1.6
TREASURE_MIN_ROE=10
TREASURE_MIN_GROSS_MARGIN=18
TREASURE_MIN_3Y_REVENUE_CAGR=5
TREASURE_MIN_REV_Q_UP=3
TREASURE_MIN_GM_Q_UP=2
TREASURE_MIN_ROE_Q_UP=2
TREASURE_MIN_FCF_MARGIN=3
TREASURE_MIN_DIVIDEND_YEARS=3
TREASURE_MIN_OCF_STABLE_YEARS=3
TREASURE_MIN_FCF_POSITIVE_YEARS=2

V14_ENABLE_VALUATION=true
DCF_DISCOUNT_RATE=0.10
DCF_GROWTH_RATE=0.025
TREASURE_MIN_MARGIN_OF_SAFETY=15
DIVIDEND_STABILITY_WEIGHT=1.0
